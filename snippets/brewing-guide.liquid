{%- doc -%}
Portable brewing-guide block: a card strip where each card opens a recipe
drawer. Self-contained — pair this with brewing-guide.scss + brewing-guide.js
(both auto-loaded below). Drop into any section; nothing here depends on the
host section.

The drawers are rendered OUTSIDE the Swiper (Swiper transforms its wrapper,
which breaks position:fixed and clips overflow), and linked to their card by
a shared id: card `data-brewing-open="ID"` ↔ modal `data-brewing-drawer="ID"`.

@param {metaobject} brewing_obj - The BREWING GUIDE SELECTIONS metaobject
(needs `heading` and a `recipes` list of BREWING GUIDE ENTRIES).
@param {string} [uid] - Unique id fragment. Defaults to the current section id.

@example
{% render 'brewing-guide', brewing_obj: section.settings.brewing_guide_selection %}
{%- enddoc -%}

{%- if brewing_obj != blank and brewing_obj.recipes.value.size > 0 -%}
{%- render 'vite-tag', entry: 'sections/styles/brewing-guide.scss' -%}
{%- render 'vite-tag', entry: 'sections/scripts/brewing-guide.js' -%}

{%- liquid
assign brewing_uid = uid | default: section.id | default: 'brewing'
-%}

<div class="brewing-guide" style="
    ">
  {% if brewing_obj.heading.value != blank %}
  <h2 class="brewing-guide__heading t-h4">{{ brewing_obj.heading.value }}</h2>
  {% endif %}

  {% comment %} Cards (inside Swiper) {% endcomment %}
  <div class="brewing-guide__list swiper" data-brewing-swiper>
    <div class="swiper-wrapper">
      {% for recipe in brewing_obj.recipes.value %}
      {% assign drawer_id = brewing_uid | append: '-' | append: forloop.index0 %}

      {%- capture card_inner -%}
      <span class="brewing-guide__card-media">
        {% if recipe.card_image.value != blank %}
        {{
        recipe.card_image.value
        | image_url: width: 800
        | image_tag: loading: 'lazy', class: 'brewing-guide__card-image', alt: recipe.card_text.value
        }}
        {% endif %}
        {% if recipe.card_video.value != blank %}
        {% assign card_video = recipe.card_video.value %}
        <video class="brewing-guide__card-video js-autoplay-video" muted loop playsinline>
          {% if card_video.sources.size > 0 %}
          {% for source in card_video.sources %}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
          {% endfor %}
          {% else %}
          <source src="{{ card_video | file_url }}">
          {% endif %}
        </video>
        {% endif %}
      </span>

      <span class="brewing-guide__card-footer">
        <span class="brewing-guide__card-text t-n1-med">
          <span class="brewing-guide__card-text-default">{{ recipe.card_text.value }}</span>
          {% if recipe.card_hover_text.value != blank %}
          <span class="brewing-guide__card-text-hover">{{ recipe.card_hover_text.value }}</span>
          {% endif %}
        </span>
        {% if recipe.card_icon.value != blank %}
        {{
        recipe.card_icon.value
        | image_url: width: 80
        | image_tag: loading: 'lazy', class: 'brewing-guide__card-icon', alt: ''
        }}
        {% endif %}
      </span>
      {%- endcapture -%}

      <div class="brewing-guide__item swiper-slide">
        {% comment %} No title = no recipe drawer; card is non-clickable. {% endcomment %}
        {% if recipe.title.value != blank %}
        <button type="button" class="brewing-guide__card" data-brewing-open="{{ drawer_id }}" aria-haspopup="dialog">
          {{ card_inner }}
        </button>
        {% else %}
        <div class="brewing-guide__card brewing-guide__card--static">
          {{ card_inner }}
        </div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </div>

  {% comment %} Drawers (outside Swiper so position:fixed works) {% endcomment %}
  {% for recipe in brewing_obj.recipes.value %}
  {% if recipe.title.value != blank %}
  {% assign drawer_id = brewing_uid | append: '-' | append: forloop.index0 %}

  <div class="brewing-guide__modal" data-brewing-drawer="{{ drawer_id }}" hidden>
    <div class="brewing-guide__overlay" data-brewing-close></div>
    <div class="brewing-guide__drawer" role="dialog" aria-modal="true" tabindex="-1"
      aria-label="{{ recipe.title.value }}">
      <div class="brewing-guide__drawer-inner">
        <button type="button" class="brewing-guide__drawer-close" data-brewing-close
          aria-label="{{ 'accessibility.close_dialog' | t }}">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M19.0711 4.92896L4.92894 19.0711" stroke="#282828" stroke-width="2" stroke-linecap="square"/>
<path d="M19.0711 19.0711L4.92892 4.92896" stroke="#282828" stroke-width="2" stroke-linecap="square"/>
</svg>

        </button>

        <div class="brewing-guide__recipe">
          <header class="brewing-guide__recipe-head">
            {% if recipe.product_image.value != blank %}
            {{
            recipe.product_image.value
            | image_url: width: 300
            | image_tag: loading: 'lazy', class: 'brewing-guide__recipe-thumb hide-below-md', alt: recipe.title.value
            }}
            {% endif %}
            <div class="brewing-guide__recipe-wrapper">
              <h3 class="brewing-guide__recipe-title t-h6">{{ recipe.title.value }}</h3>
              <dl class="brewing-guide__recipe-meta t-n1">
                {% if recipe.best_made_with.value != blank %}
                  <div>
                    <dt>Best made with:</dt>
                    <dd>{{ recipe.best_made_with.value }}</dd>
                  </div>
                {% endif %}
                {% if recipe.make_time.value != blank %}
                  <div>
                    <dt>Make time:</dt>
                    <dd>{{ recipe.make_time.value }}</dd>
                  </div>
                {% endif %}
                {% if recipe.best_served.value != blank %}
                  <div>
                    <dt>Best served:</dt>
                    <dd>{{ recipe.best_served.value }}</dd>
                  </div>
                {% endif %}
                {% if recipe.grind.value != blank %}
                  <div>
                    <dt>Grind:</dt>
                    <dd>{{ recipe.grind.value }}</dd>
                  </div>
                {% endif %}
              </dl>
            </div>
          </header>

          {% assign serving_count = recipe.serving_size_count.value | default: 0 %}
          {% if serving_count > 0 %}
          <div class="brewing-guide__servings">
            <span class="brewing-guide__servings-label t-n1">Serving size:</span>
            <div class="brewing-guide__stepper" role="group" aria-label="Serving size" data-brewing-stepper>
              {% for i in (1..serving_count) %}
              <button type="button" class="brewing-guide__stepper-btn t-n1{% if forloop.first %} is-active{% endif %}"
                data-serving="{{ i }}" aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}">
                &times; {{ i }}
              </button>
              {% endfor %}
            </div>
          </div>
          {% endif %}

          {% if recipe.ingredients.value.size > 0 %}
            <div class="brewing-guide__ingredients-wrapper">
                <div class="brewing-guide__ingredients-label t-n1">Ingredients:</div>
                          <ul class="brewing-guide__ingredients t-t4">
            {% for ingredient in recipe.ingredients.value %}
            <li class="brewing-guide__ingredient">
              <span class="brewing-guide__ingredient-name">{{ ingredient.name.value }}</span>
              <span class="brewing-guide__ingredient-qty t-n1" data-brewing-qty {% if ingredient.quantity_alt.value !=blank
                %}data-brewing-qty-static{% endif %}>{% if ingredient.quantity_alt.value != blank %}{{
                ingredient.quantity_alt.value }}{% else %}{{ ingredient.quantity.value }}{% endif %}</span>
            </li>
            {% endfor %}
          </ul>
            </div>
          {% endif %}

          {% if recipe.banner_image.value != blank or recipe.mobile_banner_image.value != blank or recipe.banner_title.value != blank %}
          <div class="brewing-guide__banner">
            {% assign banner_desktop_image = recipe.banner_image.value | default: recipe.mobile_banner_image.value %}
            {% assign banner_mobile_image = recipe.mobile_banner_image.value | default: banner_desktop_image %}
            {% if banner_desktop_image != blank %}
            {{
              banner_desktop_image
              | image_url: width: 1000
              | image_tag:
                loading: 'lazy',
                class: 'brewing-guide__banner-image brewing-guide__banner-image--desktop',
                alt: recipe.banner_title.value
            }}
            {% endif %}
            {% if banner_mobile_image != blank %}
            {{
              banner_mobile_image
              | image_url: width: 1000
              | image_tag:
                loading: 'lazy',
                class: 'brewing-guide__banner-image brewing-guide__banner-image--mobile',
                alt: recipe.banner_title.value
            }}
            {% endif %}
            <div class="brewing-guide__banner-copy">
              {% if recipe.banner_title.value != blank %}
              <span class="brewing-guide__banner-title t-s2">{{ recipe.banner_title.value }}</span>
              {% endif %}
              {% if recipe.banner_subtext.value != blank %}
              <span class="brewing-guide__banner-subtext t-t2">{{ recipe.banner_subtext.value }}</span>
              {% endif %}
              {% if recipe.cta_link.value != blank %}
              <a href="{{ recipe.cta_link.value }}" class="brewing-guide__banner-cta btn btn--cream">
                {{ recipe.cta_label.value | default: 'Shop now' }}
              </a>
              {% endif %}
            </div>
          </div>
          {% endif %}

          {% if recipe.how_to_make.value.size > 0 %}
          <div class="brewing-guide__how">
            <span class="brewing-guide__how-label t-n1">How to make:</span>
            <ol class="brewing-guide__how-list t-t4">
              {% for step in recipe.how_to_make.value %}
              <li>{{ step }}</li>
              {% endfor %}
            </ol>
          </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
  {% endif %}
  {% endfor %}
</div>
{%- endif -%}
