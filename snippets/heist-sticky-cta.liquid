{% if section.settings.show_sticky_cta %}
  <aside
    class="heist-sticky-cta"
    data-heist-sticky-cta
    aria-hidden="true"
    style="
      --sticky-bg: {{ section.settings.sticky_background }};
      --sticky-text: {{ section.settings.sticky_text_color }};
      --sticky-button-bg: {{ section.settings.sticky_button_background }};
      --sticky-button-text: {{ section.settings.sticky_button_text }};
    "
  >
    <span class="heist-sticky-cta__copy t-h7">{{ section.settings.sticky_text }}</span>
    <a class="btn" href="{{ section.settings.sticky_button_link | default: routes.all_products_collection_url }}">
      {{- section.settings.sticky_button_label -}}
    </a>
  </aside>
{% endif %}
