{%- render 'vite-tag', entry: 'sections/styles/coffee-perks.scss' -%}
{%- render 'vite-tag', entry: 'sections/scripts/coffee-perks.js' -%}

{%- liquid
  assign views = section.settings.views.value | default: section.settings.views
-%}

<section
  class="coffee-perks"
  id="shopify-section-{{ section.id }}"
  style="
    --coffee-perks-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --coffee-perks-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --coffee-perks-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --coffee-perks-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    {% if section.settings.card_background_color != blank %}--coffee-perks-card-bg: {{ section.settings.card_background_color }};{% endif %}
  "
  data-coffee-perks
>
  <div class="page-width">
    <div class="coffee-perks__inner">
      {%- if views != blank -%}
        {%- assign first_view = views | first -%}
        <div class="coffee-perks__head">
          <h2 class="coffee-perks__heading t-h4" data-coffee-perks-heading>
            {{- first_view.heading.value | default: first_view.heading | escape -}}
          </h2>
        </div>

        <div class="coffee-perks__bar">
          {%- if views.size > 1 -%}
            <button
              type="button"
              class="coffee-perks__toggle t-hyperlink"
              data-coffee-perks-toggle
              aria-controls="coffee-perks-views-{{ section.id }}"
            >
              <span data-coffee-perks-toggle-label>
                {{- first_view.toggle_label.value | default: first_view.toggle_label | escape -}}
              </span>
            </button>
          {%- endif -%}
        </div>

        <div
          class="coffee-perks__views"
          id="coffee-perks-views-{{ section.id }}"
          data-coffee-perks-views
        >
          {%- for view in views -%}
            {%- liquid
              assign view_heading = view.heading.value | default: view.heading
              assign view_label = view.toggle_label.value | default: view.toggle_label
              assign cards = view.cards.value | default: view.cards
            -%}
            <div
              class="coffee-perks__view{% if forloop.first %} is-active{% endif %}"
              data-coffee-perks-view
              data-heading="{{ view_heading | escape }}"
              data-toggle-label="{{ view_label | escape }}"
              {% unless forloop.first %}hidden{% endunless %}
              role="tabpanel"
            >
              <div class="coffee-perks__slider swiper" data-coffee-perks-swiper>
                <div class="coffee-perks__track swiper-wrapper">
                  {%- for card in cards -%}
                    {%- liquid
                      assign card_image = card.image.value | default: card.image
                      assign card_title = card.title.value | default: card.title
                      assign card_description = card.description.value | default: card.description
                      assign card_alt = card_title | strip_html | strip | escape
                    -%}
                    <article class="coffee-perks__card swiper-slide">
                      <div class="coffee-perks__card-media">
                        {%- if card_image != blank -%}
                          {{
                            card_image
                            | image_url: width: 640
                            | image_tag:
                              widths: '272, 320, 448, 544, 640',
                              sizes: '(min-width: 990px) 17rem, 14rem',
                              loading: 'lazy',
                              alt: card_alt,
                              class: 'coffee-perks__card-image'
                          }}
                        {%- else -%}
                          <div class="coffee-perks__card-placeholder" aria-hidden="true"></div>
                        {%- endif -%}
                      </div>
                      <div class="coffee-perks__card-body">
                        {%- if card_title != blank -%}
                          <h3 class="coffee-perks__card-title">{{ card_title | escape }}</h3>
                        {%- endif -%}
                        {%- if card_description != blank -%}
                          <p class="coffee-perks__card-text t-t4">
                            {{- card_description | escape | newline_to_br -}}
                          </p>
                        {%- endif -%}
                      </div>
                    </article>
                  {%- endfor -%}
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="coffee-perks__empty">
          <p class="coffee-perks__empty-title t-s3">Select a coffee perks selection</p>
          <p class="coffee-perks__empty-text t-t4">
            Add one or more <code>product_coffee_perks_selections_oh</code> entries to the
            “Views” setting to populate this section.
          </p>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Coffee perks",
  "tag": "section",
  "class": "shopify-section-coffee-perks",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "metaobject_list",
      "id": "views",
      "label": "Views",
      "metaobject_type": "pdp_coffee_perks_selections_oh"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background",
      "default": "#eeeade"
    },
    {
      "type": "header",
      "content": "Mobile padding"
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "Top",
      "default": 48
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "Bottom",
      "default": 48
    },
    {
      "type": "header",
      "content": "Desktop padding"
    },
    {
      "type": "number",
      "id": "padding_top_desktop",
      "label": "Top",
      "default": 72
    },
    {
      "type": "number",
      "id": "padding_bottom_desktop",
      "label": "Bottom",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "Coffee perks",
      "category": "Product"
    }
  ]
}
{% endschema %}
