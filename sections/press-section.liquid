{% render 'vite-tag' with 'sections/styles/press-section.scss' %}
{% render 'vite-tag' with 'sections/scripts/press-section.js' %}

{%- liquid
  assign press_selection = section.settings.press_selection.value | default: section.settings.press_selection
  assign press_entries = press_selection.press_entries.value | default: press_selection.press_entries
-%}

<section
  class="press-section"
  id="shopify-section-{{ section.id }}"
  style="
    --press-section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --press-section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --press-section-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --press-section-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    {% if section.settings.background_color != blank %}
      --press-section-bg: {{ section.settings.background_color }};
    {% endif %}
    {% if section.settings.panel_background_color != blank %}
      --press-section-panel-bg: {{ section.settings.panel_background_color }};
    {% endif %}
  "
  data-press-section
>
  {% if section.settings.background_image != blank or section.settings.background_image_mobile != blank %}
    <picture>
      {% if section.settings.background_image_mobile != blank %}
        <source
          media="(max-width: 989px)"
          srcset="{{ section.settings.background_image_mobile | image_url: width: 1500 }}"
        >
      {% endif %}
      {% if section.settings.background_image != blank %}
        {{
          section.settings.background_image
          | image_url: width: 2560
          | image_tag:
            widths: '750, 1100, 1500, 2000, 2560',
            sizes: '100vw',
            loading: 'lazy',
            class: 'press-section__background-image'
        }}
      {% else %}
        {{
          section.settings.background_image_mobile
          | image_url: width: 1500
          | image_tag:
            widths: '750, 1100, 1500',
            sizes: '100vw',
            loading: 'lazy',
            class: 'press-section__background-image'
        }}
      {% endif %}
    </picture>
  {% endif %}

  <div class="page-width">
    <div class="press-section__shell">
      <div class="press-section__slider swiper" data-press-section-slider>
        <div class="press-section__track swiper-wrapper">
          {% if press_entries != blank %}
            {% for entry in press_entries %}
              {%- liquid
                assign left_image = entry.left_image.value | default: entry.left_image
                assign newspaper_logo = entry.newspaper_logo.value | default: entry.newspaper_logo
                assign headline_field = entry.headline
                assign headline = headline_field.value | default: headline_field
                assign description_field = entry.description
                assign description = description_field.value | default: description_field
                assign bottom_right_image = entry.bottom_right_image.value | default: entry.bottom_right_image
                assign bottom_right_image_mobile = entry.mobile_bottom_right_image.value | default: entry.mobile_bottom_right_image
                assign bottom_media_desktop = bottom_right_image | default: bottom_right_image_mobile
                assign bottom_media_mobile = bottom_right_image_mobile | default: bottom_right_image
              -%}

              {% capture headline_markup %}
                {%- if headline_field != blank -%}
                  {{- headline_field | metafield_tag -}}
                {%- else -%}
                  {{- headline -}}
                {%- endif -%}
              {% endcapture %}

              {%- assign entry_alt = headline_markup | strip_html | strip_newlines | strip | escape -%}

              <article class="press-section__slide swiper-slide">
                <div class="press-section__slide-grid">
                  <div class="press-section__media hide-below-lg">
                    {% if left_image != blank %}
                      {% if left_image.media_type == 'video' %}
                        {{
                          left_image
                          | video_tag:
                            autoplay: true,
                            loop: true,
                            muted: true,
                            controls: false,
                            playsinline: true,
                            class: 'press-section__media-video'
                        }}
                      {% else %}
                        {{
                          left_image
                          | image_url: width: 1600
                          | image_tag:
                            widths: '640, 960, 1280, 1600',
                            sizes: '(min-width: 990px) 38rem, 100vw',
                            loading: 'lazy',
                            alt: entry_alt,
                            class: 'press-section__media-image'
                        }}
                      {% endif %}
                    {% else %}
                      <div class="press-section__media-placeholder" aria-hidden="true"></div>
                    {% endif %}
                  </div>

                  <div class="press-section__panel">
                    <div class="press-section__chrome">
                      <div class="press-section__pagination desktop" data-press-section-pagination></div>

                      {% if section.settings.label != blank %}
                        <p class="press-section__label t-n1-med">{{ section.settings.label | escape }}</p>
                      {% endif %}

                      <div class="press-section__navigation">
                        <button
                          class="press-section__nav-button press-section__nav-button--prev"
                          type="button"
                          aria-label="Previous press entry"
                          data-press-section-prev
                        >
                          <svg
                            width="16"
                            height="16"
                            viewBox="0 0 16 16"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path d="M15 8H3" stroke="#282828" stroke-width="2" stroke-linecap="square"/>
                            <path d="M7 3L2 8L7 13" stroke="#282828" stroke-width="2" stroke-linecap="square"/>
                          </svg>
                        </button>
                        <button
                          class="press-section__nav-button press-section__nav-button--next"
                          type="button"
                          aria-label="Next press entry"
                          data-press-section-next
                        >
                          <svg
                            width="16"
                            height="16"
                            viewBox="0 0 16 16"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path d="M1 8H13" stroke="#282828" stroke-width="2" stroke-linecap="square"/>
                            <path d="M9 3L14 8L9 13" stroke="#282828" stroke-width="2" stroke-linecap="square"/>
                          </svg>
                        </button>
                      </div>
                    </div>

                    <div class="press-section__panel-body">
                      {% if newspaper_logo != blank %}
                        <div class="press-section__logo-wrap">
                          {{
                            newspaper_logo
                            | image_url: width: 480
                            | image_tag:
                              widths: '180, 240, 320, 480',
                              sizes: '(min-width: 990px) 14rem, 10rem',
                              loading: 'lazy',
                              alt: entry_alt,
                              class: 'press-section__logo'
                          }}
                        </div>
                      {% endif %}

                      {%- if headline != blank -%}
                        <h2 class="press-section__headline t-h4">
                          {{- headline_markup -}}
                        </h2>
                      {%- endif -%}

                      <div class="press-section__bottom">
                        {%- if description != blank -%}
                          <div class="press-section__description hide-below-lg t-t2">
                            {%- if description_field != blank -%}
                              {{- description_field | metafield_tag -}}
                            {%- else -%}
                              {{- description -}}
                            {%- endif -%}
                          </div>
                        {%- endif -%}

                        <div class="press-section__bottom-media">
                          {%- if bottom_media_desktop != blank -%}
                            <div class="press-section__bottom-media-inner hide-below-lg">
                              {% if bottom_media_desktop.media_type == 'video' %}
                                {{
                                  bottom_media_desktop
                                  | video_tag:
                                    autoplay: true,
                                    loop: true,
                                    muted: true,
                                    controls: false,
                                    playsinline: true,
                                    class: 'press-section__bottom-video'
                                }}
                              {% else %}
                                {{
                                  bottom_media_desktop
                                  | image_url: width: 960
                                  | image_tag:
                                    widths: '480, 720, 960',
                                    sizes: '(min-width: 990px) 20rem, 100vw',
                                    loading: 'lazy',
                                    alt: entry_alt,
                                    class: 'press-section__bottom-image'
                                }}
                              {% endif %}
                            </div>
                          {%- endif -%}
                          {%- if bottom_media_mobile != blank -%}
                            <div class="press-section__bottom-media-inner hide-from-lg">
                              {% if bottom_media_mobile.media_type == 'video' %}
                                {{
                                  bottom_media_mobile
                                  | video_tag:
                                    autoplay: true,
                                    loop: true,
                                    muted: true,
                                    controls: false,
                                    playsinline: true,
                                    class: 'press-section__bottom-video'
                                }}
                              {% else %}
                                {{
                                  bottom_media_mobile
                                  | image_url: width: 960
                                  | image_tag:
                                    widths: '480, 720, 960',
                                    sizes: '100vw',
                                    loading: 'lazy',
                                    alt: entry_alt,
                                    class: 'press-section__bottom-image'
                                }}
                              {% endif %}
                            </div>
                          {%- endif -%}
                        </div>
                      </div>
                    </div>
                    <div class="press-section__pagination mobile" data-press-section-pagination></div>
                  </div>
                </div>
              </article>
            {% endfor %}
          {% else %}
            <article class="press-section__slide swiper-slide">
              <div class="press-section__empty">
                <p class="press-section__empty-title t-s3">Select a press metaobject</p>
                <p class="press-section__empty-text t-t4">
                  Choose a <code>homepage_press_section_selection</code> entry to populate this slider.
                </p>
              </div>
            </article>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Press section",
  "tag": "section",
  "class": "shopify-section-press-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "metaobject",
      "id": "press_selection",
      "label": "Press selection",
      "metaobject_type": "homepage_press_section_selection"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Top label",
      "default": "HOT OFF THE PRESS"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#e8e0d2"
    },
    {
      "type": "color",
      "id": "panel_background_color",
      "label": "Panel background color",
      "default": "#e6dece"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image (mobile)"
    },
    {
      "type": "header",
      "content": "Mobile padding"
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "Top",
      "default": 48
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "Bottom",
      "default": 48
    },
    {
      "type": "header",
      "content": "Desktop padding"
    },
    {
      "type": "number",
      "id": "padding_top_desktop",
      "label": "Top",
      "default": 72
    },
    {
      "type": "number",
      "id": "padding_bottom_desktop",
      "label": "Bottom",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "Press section",
      "category": "Image"
    }
  ]
}
{% endschema %}
