{%- doc -%}
  Heist FM Player

  Custom Shopify music player section.
  Supports multiple MP3 tracks, next/previous controls, shuffle, loop,
  progress seeking, cover image, Apple Music link, and Spotify link.

  Usage:
  - Upload MP3 files in Shopify Admin > Content > Files.
  - Enter only the exact MP3 file name in each track block.
  - Example: heist-song-1.mp3
{%- enddoc -%}

{% comment %} {{ 'heist-fm-player.css' | asset_url | stylesheet_tag }} {% endcomment %}
{%- render 'vite-tag', entry: 'sections/styles/heist-fm-player.css' -%} 
{%- render 'vite-tag', entry: 'sections/scripts/heist-fm-player.js' -%}

<section
  id="HeistFmPlayer-{{ section.id }}"
  class="heist-fm-player"
>
  <div class="heist-fm-player__inner page-width">
    <div class="heist-fm-player__card" data-heist-player>
      <audio data-heist-audio preload="metadata"></audio>

      <script type="application/json" data-heist-tracks>
        [
          {%- for block in section.blocks -%}
            {%- liquid
              assign audio_file_name = block.settings.audio_file_name | strip
              assign audio_src = ''

              if audio_file_name != blank
                assign audio_src = audio_file_name | file_url
              endif
            -%}

            {
              "title": {{ block.settings.track_title | json }},
              "artist": {{ block.settings.track_artist | json }},
              "audio": {{ audio_src | json }},
              "cover": {%- if block.settings.cover_image != blank -%}
                {{ block.settings.cover_image | image_url: width: 160 | json }}
              {%- else -%}
                ""
              {%- endif -%}
            }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ]
      </script>

      <div class="heist-fm-player__media">
        <div class="heist-fm-player__cover-wrap">
          <img
            class="heist-fm-player__cover"
            data-heist-cover
            src=""
            alt=""
            width="72"
            height="72"
            loading="lazy"
          >

          <div class="heist-fm-player__cover-placeholder" data-heist-placeholder>
            FM
          </div>
        </div>

        <div class="heist-fm-player__content">
          <div class="heist-fm-player__top">
            <div>
              <h2 class="heist-fm-player__title">
                {{ section.settings.heading | escape }}
              </h2>

              <p class="heist-fm-player__subtitle" data-heist-track-title>
                {{ section.settings.subheading | escape }}
              </p>
            </div>

            <div class="heist-fm-player__links">
              {%- if section.settings.apple_music_url != blank -%}
                <a
                  href="{{ section.settings.apple_music_url }}"
                  class="heist-fm-player__link"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Open Apple Music in a new tab"
                >
                  Apple
                </a>
              {%- endif -%}

              {%- if section.settings.spotify_url != blank -%}
                <a
                  href="{{ section.settings.spotify_url }}"
                  class="heist-fm-player__link"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Open Spotify in a new tab"
                >
                  Spotify
                </a>
              {%- endif -%}
            </div>
          </div>

          <div class="heist-fm-player__progress">
            <span class="heist-fm-player__time" data-heist-current-time>0:00</span>

            <input
              class="heist-fm-player__range"
              data-heist-progress
              type="range"
              min="0"
              max="100"
              value="0"
              step="0.1"
              aria-label="Audio progress"
            >

            <span class="heist-fm-player__time" data-heist-duration>0:00</span>
          </div>

          <div class="heist-fm-player__controls">
            <button
              type="button"
              class="heist-fm-player__control"
              data-heist-action="shuffle"
              aria-label="Shuffle"
            >
              ↝
            </button>

            <button
              type="button"
              class="heist-fm-player__control"
              data-heist-action="previous"
              aria-label="Previous track"
            >
              ◀
            </button>

            <button
              type="button"
              class="heist-fm-player__play"
              data-heist-action="toggle"
              aria-label="Play audio"
            >
              <span data-heist-play-icon>▶</span>
            </button>

            <button
              type="button"
              class="heist-fm-player__control"
              data-heist-action="next"
              aria-label="Next track"
            >
              ▶
            </button>

            <button
              type="button"
              class="heist-fm-player__control"
              data-heist-action="loop"
              aria-label="Loop current track"
            >
              ↺
            </button>
          </div>

          <p class="heist-fm-player__status" data-heist-status>
            Ready to steal the night again? Cue Heist music.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Heist FM Player",
  "tag": "section",
  "class": "section-heist-fm-player",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Player heading",
      "default": "HEIST.FM"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Default subtitle",
      "default": "Ready to steal the night again? Cue Heist music."
    },
    {
      "type": "url",
      "id": "apple_music_url",
      "label": "Apple Music URL"
    },
    {
      "type": "url",
      "id": "spotify_url",
      "label": "Spotify URL"
    }
  ],
  "blocks": [
    {
      "type": "track",
      "name": "Track",
      "settings": [
        {
          "type": "text",
          "id": "track_title",
          "label": "Track title",
          "default": "Heist Track"
        },
        {
          "type": "text",
          "id": "track_artist",
          "label": "Artist / description",
          "default": "Heist Coffee Co."
        },
        {
          "type": "text",
          "id": "audio_file_name",
          "label": "MP3 file name",
          "info": "Upload MP3 in Shopify Admin > Content > Files, then enter only the exact file name. Example: heist-song-1.mp3"
        },
        {
          "type": "image_picker",
          "id": "cover_image",
          "label": "Track cover image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Heist FM Player",
      "blocks": [
        {
          "type": "track"
        },
        {
          "type": "track"
        },
        {
          "type": "track"
        }
      ]
    }
  ]
}
{% endschema %}