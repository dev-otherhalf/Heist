{%- render 'vite-tag', entry: 'sections/styles/clean-job.scss' -%}
{%- render 'vite-tag', entry: 'sections/scripts/clean-job.js' -%}

{%- liquid
  assign heading = section.settings.heading
  assign clean_video = section.settings.video
  assign poster_image = section.settings.video_fallback_image
  assign annotation_value = section.settings.video_number
  assign background_image = section.settings.background_image
  assign background_image_mobile = section.settings.background_image_mobile
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --clean-job-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --clean-job-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --clean-job-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --clean-job-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    {%- if section.settings.background_color != blank %}
      --clean-job-bg: {{ section.settings.background_color }};
    {%- endif %}
  }
{%- endstyle -%}

<section class="clean-job" data-clean-job>
  {%- if background_image != blank or background_image_mobile != blank -%}
    <picture class="clean-job__background" aria-hidden="true">
      {%- if background_image_mobile != blank -%}
        <source
          media="(max-width: 989px)"
          srcset="{{ background_image_mobile | image_url: width: 1200 }}"
        >
      {%- endif -%}
      {%- assign background_fallback = background_image | default: background_image_mobile -%}
      {{
        background_fallback
        | image_url: width: 2560
        | image_tag:
          widths: '750, 1100, 1500, 2000, 2560',
          sizes: '100vw',
          loading: 'lazy',
          alt: '',
          class: 'clean-job__background-image'
      }}
    </picture>
  {%- endif -%}

  <div class="clean-job__inner">
    <div class="clean-job__grid">
      {%- if heading != blank -%}
        <h2 class="clean-job__heading t-h4">{{ heading }}</h2>
      {%- endif -%}

      <div class="clean-job__media">
        <div class="clean-job__media-inner">
          {%- if clean_video != blank -%}
            <video
              class="clean-job__video js-autoplay-video"
              preload="none"
              {% if poster_image != blank %}
                poster="{{ poster_image | image_url: width: 1200 }}"
              {% endif %}
              muted
              loop
              playsinline
            >
              {%- if clean_video.sources.size > 0 -%}
                {%- for source in clean_video.sources -%}
                  <source src="{{ source.url }}" type="{{ source.mime_type }}">
                {%- endfor -%}
              {%- else -%}
                <source src="{{ clean_video | file_url }}">
              {%- endif -%}
            </video>
          {%- elsif poster_image != blank -%}
            {{
              poster_image
              | image_url: width: 1200
              | image_tag:
                widths: '600, 900, 1200',
                sizes: '(min-width: 990px) 30rem, 100vw',
                loading: 'lazy',
                alt: poster_image.alt,
                class: 'clean-job__poster'
            }}
          {%- endif -%}

          <div class="clean-job__frame" aria-hidden="true"></div>

          {%- if annotation_value != blank -%}
            <div class="clean-job__annotation t-n2-med" data-rolling-annotation>
              <span class="clean-job__sr">{{ annotation_value }}</span>
              <span class="clean-job__digits" aria-hidden="true">
                {%- assign annotation_groups = annotation_value | split: ' ' -%}
                {%- for group in annotation_groups -%}
                  <span class="clean-job__digit-group">
                    {%- assign annotation_chars = group | split: '' -%}
                    {%- for char in annotation_chars -%}
                      <span class="clean-job__digit" data-digit="{{ char }}">
                        <span class="clean-job__digit-strip" data-digit-strip>
                          <span>0</span><span>1</span><span>2</span><span>3</span><span>4</span><span>5</span
                          ><span>6</span><span>7</span><span>8</span><span>9</span>
                        </span>
                      </span>
                    {%- endfor -%}
                  </span>
                {%- endfor -%}
              </span>
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- if section.blocks.size > 0 -%}
        <ul class="clean-job__features">
          {%- for block in section.blocks -%}
            {%- if block.settings.text != blank -%}
              <li class="clean-job__feature t-h6" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Clean job",
  "tag": "section",
  "class": "shopify-section-clean-job",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "The Cleanest Job in Coffee History."
    },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "image_picker",
      "id": "video_fallback_image",
      "label": "Video fallback image",
      "info": "Shown as the poster and used when no video is set."
    },
    {
      "type": "text",
      "id": "video_number",
      "label": "Video number",
      "info": "Digits roll up on scroll. Separate groups with a space.",
      "default": "24724 1632 248"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Desktop background"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Mobile background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "header",
      "content": "Mobile padding"
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "Top",
      "default": 48
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "Bottom",
      "default": 48
    },
    {
      "type": "header",
      "content": "Desktop padding"
    },
    {
      "type": "number",
      "id": "padding_top_desktop",
      "label": "Top",
      "default": 96
    },
    {
      "type": "number",
      "id": "padding_bottom_desktop",
      "label": "Bottom",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Water Decaf Method"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Clean job",
      "category": "Product",
      "blocks": [
        { "type": "text", "settings": { "text": "Water Decaf Method" } },
        { "type": "text", "settings": { "text": "No Solvents / Chemicals" } },
        { "type": "text", "settings": { "text": "99.9% Caffeine Removed" } },
        { "type": "text", "settings": { "text": "Every Batch on File" } }
      ]
    }
  ]
}
{% endschema %}
