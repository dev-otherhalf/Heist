{%- render 'vite-tag', entry: 'sections/styles/gallery-showcase.scss' -%}
{%- if section.blocks.size > 0 -%}
  <script
    src="{{ 'marquee.js' | asset_url }}"
    type="module"
    fetchpriority="low"
  ></script>
{%- endif -%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --gallery-showcase-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --gallery-showcase-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --gallery-showcase-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --gallery-showcase-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
  }
{%- endstyle -%}

<section class="gallery-showcase">
  {%- if section.settings.heading != blank or section.settings.cta_label != blank -%}
    <div class="gallery-showcase__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="gallery-showcase__heading t-h4">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <a
          {% if section.settings.cta_link != blank %}
            href="{{ section.settings.cta_link }}"
          {% else %}
            role="link"
            aria-disabled="true"
          {% endif %}
          class="gallery-showcase__cta btn btn--cream"
        >
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="gallery-showcase__row">
      <marquee-component
        class="gallery-showcase__marquee"
        data-speed-factor="{{ section.settings.marquee_speed }}"
      >
        <div class="gallery-showcase__wrapper" ref="wrapper">
          <div class="gallery-showcase__content" ref="content">
            <div class="gallery-showcase__track" ref="marqueeItems[]">
              {%- for block in section.blocks -%}
                {%- if block.type == 'card' -%}
                  {%- if block.settings.video != blank or block.settings.image != blank -%}
                    <div class="gallery-showcase__card" {{ block.shopify_attributes }}>
                      {%- if block.settings.video != blank -%}
                        {{
                          block.settings.video
                          | video_tag:
                            image_size: '800x',
                            loop: true,
                            muted: true,
                            autoplay: false,
                            preload: 'none',
                            controls: false,
                            playsinline: true,
                            class: 'gallery-showcase__media js-autoplay-video'
                        }}
                      {%- else -%}
                        {%- assign card_alt = block.settings.image.alt | default: 'Drink Heist' -%}
                        {% render 'responsive-image',
                          desktop_image: block.settings.image,
                          mobile_image: block.settings.image,
                          alt: card_alt,
                          class: 'gallery-showcase__media-wrapper',
                          image_class: 'gallery-showcase__media',
                          sizes: '(max-width: 749px) 50vw, 20vw'
                        %}
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        </div>
      </marquee-component>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Gallery showcase",
  "tag": "section",
  "class": "shopify-section-gallery-showcase",
  "settings": [
    { "type": "header", "content": "Content" },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "For those who are serious about coffee."
    },
    { "type": "header", "content": "CTA" },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Follow @Heist"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    { "type": "header", "content": "Marquee" },
    {
      "type": "range",
      "id": "marquee_speed",
      "label": "Scroll duration",
      "info": "Higher is slower.",
      "min": 10,
      "max": 90,
      "step": 5,
      "unit": "s",
      "default": 40
    },
    { "type": "header", "content": "Mobile padding" },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "Top padding",
      "default": 24
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding",
      "default": 24
    },
    { "type": "header", "content": "Desktop padding" },
    {
      "type": "number",
      "id": "padding_top_desktop",
      "label": "Top padding",
      "default": 64
    },
    {
      "type": "number",
      "id": "padding_bottom_desktop",
      "label": "Bottom padding",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "Takes priority over the image above when set."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gallery showcase",
      "category": "Media",
      "blocks": [{ "type": "card" }, { "type": "card" }, { "type": "card" }, { "type": "card" }, { "type": "card" }]
    }
  ]
}
{% endschema %}
