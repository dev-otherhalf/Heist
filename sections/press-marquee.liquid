{% render 'vite-tag' with 'sections/styles/press-marquee.scss' %}
<script
  src="{{ 'marquee.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{%- liquid
  assign logo_blocks = section.blocks | where: 'type', 'logo'
-%}

<section
  class="press-marquee"
  id="shopify-section-{{ section.id }}"
  style="
    --press-marquee-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --press-marquee-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --press-marquee-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --press-marquee-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
  "
  data-press-marquee
>
  <div class="press-marquee__inner">
    {% if section.settings.label != blank %}
      <p class="press-marquee__label t-n1">{{ section.settings.label | escape }}</p>
    {% endif %}

    {% if logo_blocks.size > 0 %}
      <marquee-component
        class="press-marquee__marquee{% if section.settings.enable_marquee_desktop == false %} press-marquee__marquee--mobile-only{% endif %}"
        data-speed-factor="25"
      >
        <div class="press-marquee__wrapper" ref="wrapper">
          <div class="press-marquee__content" ref="content">
            <div class="press-marquee__track" ref="marqueeItems[]">
              {% for block in logo_blocks %}
                {% if block.settings.image != blank %}
                  <div
                    class="press-marquee__logo"
                    {{ block.shopify_attributes }}
                  >
                    {{
                      block.settings.image
                      | image_url: width: 300
                      | image_tag:
                        widths: '150, 225, 300',
                        sizes: '(min-width: 990px) 9rem, 6rem',
                        loading: 'lazy',
                        alt: block.settings.image.alt | default: 'Logo',
                        class: 'press-marquee__logo-image'
                    }}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>
      </marquee-component>

      {% unless section.settings.enable_marquee_desktop %}
        <div class="press-marquee__static">
          {% for block in logo_blocks %}
            {% if block.settings.image != blank %}
              <div
                class="press-marquee__logo"
                {{ block.shopify_attributes }}
              >
                {{
                  block.settings.image
                  | image_url: width: 300
                  | image_tag:
                    widths: '150, 225, 300',
                    sizes: '9rem',
                    loading: 'lazy',
                    alt: block.settings.image.alt | default: 'Logo',
                    class: 'press-marquee__logo-image'
                }}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endunless %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Press marquee",
  "tag": "section",
  "class": "shopify-section-press-marquee",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "First to report:"
    },
    {
      "type": "header",
      "content": "Desktop"
    },
    {
      "type": "checkbox",
      "id": "enable_marquee_desktop",
      "label": "Enable marquee on desktop",
      "info": "When off, logos display in a static row instead of scrolling",
      "default": false
    },
    {
      "type": "header",
      "content": "Mobile padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Desktop padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Top",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Bottom",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Press marquee",
      "category": "Text"
    }
  ]
}
{% endschema %}
