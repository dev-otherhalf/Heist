{% liquid
  assign desktop_menu = section.settings.desktop_menu
  assign mobile_menu = section.settings.mobile_menu
  if mobile_menu == blank
    assign mobile_menu = desktop_menu
  endif

  assign is_home = false
  if request.page_type == 'index'
    assign is_home = true
  endif
%}

<header-component
  id="header-component"
  class="heist-header{% if is_home %} heist-header--home{% else %} heist-header--inner{% endif %}"
  data-heist-header
  data-skip-node-update
  {% if is_home %}
    transparent="always"
  {% endif %}
  style="
    --heist-home-text: {{ section.settings.home_text_color }};
    --heist-inner-text: {{ section.settings.inner_text_color }};
    --heist-mobile-bg: {{ section.settings.mobile_background }};
    --heist-mobile-text: {{ section.settings.mobile_text_color }};
    --heist-drawer-bg: {{ section.settings.drawer_background }};
    --heist-drawer-text: {{ section.settings.drawer_text_color }};
    --heist-accent: {{ section.settings.accent_color }};
  "
>
  {% content_for 'blocks' %}

  {% render 'heist-header-desktop', section: section, menu: desktop_menu, is_home: is_home %}

  {% render 'heist-header-mobile', section: section, menu: mobile_menu %}
</header-component>

{% render 'heist-sticky-cta', section: section %}

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if settings.logo != blank %}"logo": {{ settings.logo | image_url: width: 500 | prepend: 'https:' | json }},{% endif %}
    "url": {{ request.origin | json }}
  }
</script>

{% schema %}
{
  "name": "Heist header",
  "tag": "header",
  "class": "header-section heist-header-section",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "_heist-announcement"
    },
    {
      "type": "_heist-mobile-social-link"
    },
    {
      "type": "_heist-fm-player"
    }
  ],
  "settings": [
    { "type": "header", "content": "Menus" },
    { "type": "link_list", "id": "desktop_menu", "label": "Desktop menu", "default": "main-menu" },
    {
      "type": "link_list",
      "id": "mobile_menu",
      "label": "Mobile menu",
      "info": "Leave blank to use the desktop menu."
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "Customer account menu",
      "default": "customer-account-main-menu"
    },

    { "type": "header", "content": "Logo and links" },
    { "type": "image_picker", "id": "logo", "label": "Header logo", "info": "Falls back to the theme logo." },
    {
      "type": "range",
      "id": "desktop_logo_width",
      "label": "Desktop logo width",
      "min": 80,
      "max": 260,
      "step": 4,
      "unit": "px",
      "default": 172
    },
    {
      "type": "range",
      "id": "mobile_logo_width",
      "label": "Mobile logo width",
      "min": 80,
      "max": 220,
      "step": 4,
      "unit": "px",
      "default": 148
    },
    { "type": "text", "id": "shop_label", "label": "Home left link label", "default": "SHOP NOW" },
    { "type": "url", "id": "shop_link", "label": "Home left link" },
    { "type": "text", "id": "mobile_home_title", "label": "Home mobile center text", "default": "WORLD-CLASS DECAF" },

    { "type": "header", "content": "Header colors" },
    { "type": "color", "id": "home_text_color", "label": "Home text", "default": "#eeeade" },
    { "type": "color", "id": "inner_text_color", "label": "Other pages text", "default": "#161414" },
    { "type": "color", "id": "mobile_background", "label": "Mobile background", "default": "#eeeade" },
    { "type": "color", "id": "mobile_text_color", "label": "Mobile text", "default": "#161414" },
    { "type": "color", "id": "drawer_background", "label": "Mobile drawer background", "default": "#eeeade" },
    { "type": "color", "id": "drawer_text_color", "label": "Mobile drawer text", "default": "#161414" },
    { "type": "color", "id": "accent_color", "label": "Accent/button color", "default": "#ff3b27" },

    { "type": "header", "content": "Mobile drawer feature" },
    { "type": "image_picker", "id": "mobile_menu_image", "label": "Feature image" },
    { "type": "text", "id": "mobile_cta_label", "label": "Feature button", "default": "SHOP THE HEIST" },
    { "type": "url", "id": "mobile_cta_link", "label": "Feature button link" },

    { "type": "header", "content": "Scroll-down sticky CTA" },
    { "type": "checkbox", "id": "show_sticky_cta", "label": "Show sticky CTA on scroll down", "default": true },
    { "type": "text", "id": "sticky_text", "label": "Text", "default": "Coffee Without a Curfew." },
    { "type": "text", "id": "sticky_button_label", "label": "Button label", "default": "SHOP NOW" },
    { "type": "url", "id": "sticky_button_link", "label": "Button link" },
    { "type": "color", "id": "sticky_background", "label": "Background", "default": "#eeeade" },
    { "type": "color", "id": "sticky_text_color", "label": "Text", "default": "#161414" },
    { "type": "color", "id": "sticky_button_background", "label": "Button background", "default": "#ff3b27" },
    { "type": "color", "id": "sticky_button_text", "label": "Button text", "default": "#161414" }
  ],
  "presets": [
    {
      "name": "Heist header",
      "blocks": [{ "type": "_heist-announcement" }]
    }
  ]
}
{% endschema %}
