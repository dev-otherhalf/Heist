{%- render 'vite-tag', entry: 'sections/styles/full-briefing.scss' -%}
{%- render 'vite-tag', entry: 'sections/scripts/full-briefing.js' -%}

{%- liquid
  assign briefing = section.settings.briefing.value | default: section.settings.briefing
  assign heading = briefing.heading.value | default: briefing.heading
  assign feature_image = briefing.feature_image.value | default: briefing.feature_image
  assign faqs = briefing.faqs.value | default: briefing.faqs
  assign gallery = briefing.gallery_images.value | default: briefing.gallery_images
  assign button_label = briefing.button_label.value | default: briefing.button_label
  assign button_link = briefing.button_link.value | default: briefing.button_link
  assign heading_alt = heading | strip_html | strip | escape
-%}

<section
  class="full-briefing"
  id="shopify-section-{{ section.id }}"
  style="
    --full-briefing-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --full-briefing-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --full-briefing-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --full-briefing-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
  "
  data-full-briefing
>
  {% if section.settings.background_image_desktop != blank or section.settings.background_image_mobile != blank %}
    <picture class="full-briefing__background">
      {% if section.settings.background_image_mobile != blank %}
        <source
          media="(max-width: 989px)"
          srcset="{{ section.settings.background_image_mobile | image_url: width: 1500 }}"
        >
      {% endif %}
      {% if section.settings.background_image_desktop != blank %}
        {{
          section.settings.background_image_desktop
          | image_url: width: 2560
          | image_tag:
            widths: '750, 1100, 1500, 2000, 2560',
            sizes: '100vw',
            loading: 'lazy',
            class: 'full-briefing__background-image'
        }}
      {% else %}
        {{
          section.settings.background_image_mobile
          | image_url: width: 1500
          | image_tag:
            widths: '750, 1100, 1500',
            sizes: '100vw',
            loading: 'lazy',
            class: 'full-briefing__background-image'
        }}
      {% endif %}
    </picture>
  {% endif %}

  {%- if briefing != blank -%}
    <div class="full-briefing__grid">
      <div class="full-briefing__media">
        <div class="full-briefing__media-inner">
          {%- if feature_image != blank -%}
            {{
              feature_image
              | image_url: width: 1600
              | image_tag:
                widths: '375, 640, 776, 1000, 1400, 1600',
                sizes: '(min-width: 990px) 54vw, 100vw',
                loading: 'lazy',
                alt: heading_alt,
                class: 'full-briefing__media-image'
            }}
          {%- else -%}
            <div class="full-briefing__media-placeholder" aria-hidden="true"></div>
          {%- endif -%}
        </div>
        {%- if heading != blank -%}
          <h2 class="full-briefing__heading t-h4">{{ heading | escape }}</h2>
        {%- endif -%}
      </div>

      <div class="full-briefing__content">
        {%- if faqs != blank -%}
          <div class="full-briefing__faqs">
            {%- for faq in faqs -%}
              {%- liquid
                assign question = faq.question.value | default: faq.question
                assign answer = faq.answer.value | default: faq.answer
              -%}
              <details class="full-briefing__faq" name="full-briefing-{{ section.id }}">
                <summary class="full-briefing__q">
                  <span class="full-briefing__q-text t-n1">{{ question | escape }}</span>
                  <span class="full-briefing__q-icon" aria-hidden="true">
                    <svg
                      class="full-briefing__q-icon-minus"
                      width="16"
                      height="16"
                      viewBox="0 0 16 16"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <path d="M14.6668 8H1.3335" stroke="#282828" stroke-width="2" stroke-linecap="square"/>
                    </svg>

                    <svg
                      class="full-briefing__q-icon-plus"
                      width="16"
                      height="16"
                      viewBox="0 0 16 16"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <g clip-path="url(#clip0_6274_17847)">
                      <path d="M8 1.33325V14.6666" stroke="#282828" stroke-width="2" stroke-linecap="square"/>
                      <path d="M14.6668 8H1.3335" stroke="#282828" stroke-width="2" stroke-linecap="square"/>
                      </g>
                      <defs>
                      <clipPath id="clip0_6274_17847">
                      <rect width="16" height="16" fill="white"/>
                      </clipPath>
                      </defs>
                    </svg>
                  </span>
                </summary>
                {%- if answer != blank -%}
                  <div class="full-briefing__a">
                    <div class="full-briefing__a-inner t-t4">{{ answer | escape | newline_to_br }}</div>
                  </div>
                {%- endif -%}
              </details>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if gallery != blank -%}
          <div class="full-briefing__gallery">
            {%- for image in gallery limit: 3 -%}
              <div class="full-briefing__gallery-item">
                {{
                  image
                  | image_url: width: 480
                  | image_tag:
                    widths: '104, 172, 344, 480',
                    sizes: '(min-width: 990px) 11rem, 30vw',
                    loading: 'lazy',
                    alt: '',
                    class: 'full-briefing__gallery-image'
                }}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if button_label != blank -%}
          {% assign words = button_label | split: ' ' %}
          {% assign total = words.size %}
          {% assign half = total | plus: 1 | divided_by: 2 %}

          {% capture first_half %}
            {% for word in words limit: half %}
              {{ word }}{% unless forloop.last %} {% endunless %}
            {% endfor %}
          {% endcapture %}

          {% capture second_half %}
            {% for word in words offset: half %}
              {{ word }}{% unless forloop.last %} {% endunless %}
            {% endfor %}
          {% endcapture %}

          <a
            class="btn btn--dark btn--block btn--split full-briefing__cta"
            {% if button_link != blank %}
              href="{{ button_link }}"
            {% else %}
              role="link" aria-disabled="true"
            {% endif %}
          >
            <span class="btn__text">{{ first_half | strip | escape }}</span>
            {% if second_half != blank %}
              <span class="btn__lines" aria-hidden="true"></span>
              <span class="btn__text">{{ second_half | strip | escape }}</span>
            {% endif %}
          </a>
        {%- endif -%}
      </div>
    </div>
  {%- else -%}
    <div class="full-briefing__empty">
      <p class="full-briefing__empty-title t-s3">Select a full briefing selection</p>
      <p class="full-briefing__empty-text t-t4">
        Choose a <code>pdp_full_briefing_selections_oh</code> entry in the section settings to populate this section.
      </p>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Full briefing",
  "tag": "section",
  "class": "shopify-section-full-briefing",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "metaobject",
      "id": "briefing",
      "label": "Briefing",
      "metaobject_type": "pdp_full_briefing_selections_oh"
    },
    {
      "type": "header",
      "content": "Background images"
    },
    {
      "type": "image_picker",
      "id": "background_image_desktop",
      "label": "Desktop background image"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Mobile background image"
    },
    {
      "type": "header",
      "content": "Mobile padding"
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "Bottom",
      "default": 48
    },
    {
      "type": "header",
      "content": "Desktop padding"
    },
    {
      "type": "number",
      "id": "padding_top_desktop",
      "label": "Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_bottom_desktop",
      "label": "Bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Full briefing",
      "category": "Product"
    }
  ]
}
{% endschema %}
