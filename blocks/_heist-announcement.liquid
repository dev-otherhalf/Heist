{% render 'heist-announcement-bar', block: block %}

{% schema %}
{
  "name": "Heist announcement bar",
  "settings": [
    { "type": "text", "id": "text", "label": "Text", "default": "FREE SHIPPING ON SUBSCRIPTIONS" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "SHOP NOW" },
    { "type": "url", "id": "link", "label": "Link" },
    { "type": "color", "id": "home_background", "label": "Home background", "default": "#ff3b27" },
    { "type": "color", "id": "home_text_color", "label": "Home text", "default": "#161414" },
    { "type": "color", "id": "inner_background", "label": "Other pages background", "default": "#ff3b27" },
    { "type": "color", "id": "inner_text_color", "label": "Other pages text", "default": "#161414" },
    { "type": "color", "id": "mobile_home_background", "label": "Home mobile background", "default": "#4489e8" },
    { "type": "color", "id": "mobile_home_text_color", "label": "Home mobile text", "default": "#161414" },
    { "type": "color", "id": "mobile_background", "label": "Other mobile pages background", "default": "#ff3b27" },
    { "type": "color", "id": "mobile_text_color", "label": "Other mobile pages text", "default": "#161414" }
  ],
  "presets": [{ "name": "Heist announcement bar" }]
}
{% endschema %}
