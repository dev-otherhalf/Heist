{% comment %}
  Product FAQs Accordion

  Renders an accordion of FAQ rows sourced from the product metafield
  `custom.product_faqs_accordion_entries_oh` — a list of metaobjects of type
  `product_faqs_accordion_entries_oh`. Each entry provides:
    - questions (single line text) → the summary/question
    - answered  (rich text)        → the expanded answer

  Add this block inside the Product information section. It renders nothing when
  the product has no FAQ entries assigned.
{% endcomment %}

{% render 'vite-tag' with 'sections/styles/product-faqs.scss' %}

{% liquid
  assign product = closest.product
  if request.visual_preview_mode and product == blank
    assign product = collections.all.products.first
  endif
  assign faqs = product.metafields.custom.product_faqs_accordion_entries_oh.value
%}

{% if faqs != blank and faqs.size > 0 %}
  <div
    class="product-faqs"
    style="
      padding-block: {{ block.settings.padding-block-start }}px {{ block.settings.padding-block-end }}px;
    "
    {{ block.shopify_attributes }}
  >
    {% if block.settings.heading != blank %}
      <h2 class="product-faqs__heading t-n1">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="product-faqs__list">
      {% for faq in faqs %}
        {%- assign question = faq.questions.value -%}
        {%- assign answer = faq.answered |  metafield_tag -%}
        {%- if question == blank and answer == blank -%}
          {%- continue -%}
        {%- endif -%}
        <details
          class="product-faqs__item"
          {% if forloop.first and block.settings.open_first %}open{% endif %}
        >
          <summary class="product-faqs__summary t-n1">
            <span class="product-faqs__question">{{ question }}</span>
            <span class="product-faqs__icon" aria-hidden="true"></span>
          </summary>
          <div class="product-faqs__answer t-t4 rte">
            {{ answer }}
          </div>
        </details>
      {% endfor %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Product FAQs",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Optional label shown above the accordion. Leave blank to hide."
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "label": "Open first row by default",
      "default": false
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Product FAQs",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
